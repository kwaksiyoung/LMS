<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.co.lms.mapper.UserMapper">

    <!-- ============================================
         사용자 VO 매핑
         ============================================ -->
    <resultMap id="userMap" type="UserVO">
        <id column="user_id" property="userId"/>
        <result column="tenant_id" property="tenantId"/>
        <result column="user_nm" property="userName"/>
        <result column="password" property="password"/>
        <result column="email" property="email"/>
        <result column="phone" property="phone"/>
        <result column="address" property="address"/>
        <result column="dept_cd" property="deptCd"/>
        <result column="dept_nm" property="deptNm"/>
        <result column="use_yn" property="useYn"/>
        <result column="reg_dt" property="regDt"/>
        <result column="upd_dt" property="updDt"/>
    </resultMap>

    <!-- ============================================
         사용자 조회 (ID로)
         ============================================ -->
    <select id="selectUser" parameterType="string" resultMap="userMap">
        SELECT user_id, tenant_id, user_nm, password, email, phone, address, dept_cd, use_yn, reg_dt, upd_dt
        FROM tb_user
        WHERE user_id = #{userId}
    </select>

    <!-- ============================================
         사용자 목록 조회
         ============================================ -->
    <select id="selectUserList" parameterType="UserVO" resultMap="userMap">
        SELECT user_id, tenant_id, user_nm, email, phone, address, dept_cd, use_yn, reg_dt, upd_dt
        FROM tb_user
        WHERE 1=1
        <if test="tenantId != null and tenantId != ''">
            AND tenant_id = #{tenantId}
        </if>
        <if test="useYn != null and useYn != ''">
            AND use_yn = #{useYn}
        </if>
        <if test="deptCd != null and deptCd != ''">
            AND dept_cd = #{deptCd}
        </if>
        ORDER BY reg_dt DESC
    </select>

    <!-- ============================================
         사용자 등록
         ============================================ -->
    <insert id="insertUser" parameterType="UserVO">
        INSERT INTO tb_user (user_id, tenant_id, user_nm, password, email, phone, address, dept_cd, use_yn, reg_dt, upd_dt)
        VALUES (#{userId}, #{tenantId}, #{userName}, #{password}, #{email}, #{phone}, #{address}, #{deptCd}, 'Y', NOW(), NOW())
    </insert>

    <!-- ============================================
         사용자 수정
         ============================================ -->
    <update id="updateUser" parameterType="UserVO">
        UPDATE tb_user
        SET user_nm = #{userName},
            email = #{email},
            phone = #{phone},
            address = #{address},
            dept_cd = #{deptCd},
            upd_dt = NOW()
        WHERE user_id = #{userId} AND tenant_id = #{tenantId}
    </update>

    <!-- ============================================
         사용자 삭제
         ============================================ -->
    <delete id="deleteUser" parameterType="string">
        UPDATE tb_user
        SET use_yn = 'N', upd_dt = NOW()
        WHERE user_id = #{userId}
        AND tenant_id IS NOT NULL
    </delete>

    <!-- ============================================
         로그인 사용자 조회
         ============================================ -->
    <select id="selectUserForLogin" parameterType="map" resultMap="userMap">
        SELECT user_id, tenant_id, user_nm, password, email, phone, address, dept_cd, use_yn, reg_dt, upd_dt
        FROM tb_user
        WHERE user_id = #{userId} AND tenant_id = #{tenantId} AND use_yn = 'Y'
    </select>

    <!-- ============================================
         사용자 수 조회
         ============================================ -->
    <select id="selectUserCount" parameterType="UserVO" resultType="int">
        SELECT COUNT(*)
        FROM tb_user
         WHERE 1=1
         <if test="tenantId != null and tenantId != ''">
             AND tenant_id = #{tenantId}
         </if>
         <if test="useYn != null and useYn != ''">
             AND use_yn = #{useYn}
         </if>
     </select>

     <!-- ============================================
          사용자에게 역할 할당
          ============================================ -->
     <insert id="assignRoleToUser" parameterType="map">
         INSERT INTO tb_user_role (user_id, role_cd, tenant_id)
         VALUES (#{userId}, #{roleCd}, #{tenantId})
     </insert>

     <!-- ============================================
          사용자의 역할 목록 조회
          ============================================ -->
     <select id="selectUserRoles" parameterType="map" resultType="string">
         SELECT role_cd
         FROM tb_user_role
         WHERE user_id = #{userId} AND tenant_id = #{tenantId}
         ORDER BY role_cd
     </select>

 </mapper>
